# --- Telegram ---
# Токен от @BotFather (перевыпусти текущий, он засветился!)
BOT_TOKEN=000000:REPLACE_ME
BOT_USERNAME=Neuro_dropbot
# Кому слать уведомления о заказах (твой telegram user id)
ADMIN_IDS=123456789

# --- ЮMoney (кошелёк + QuickPay + HTTP-уведомления) ---
# 16-значный номер кошелька (yoomoney.ru -> Настройки -> Счета), например 4100111111111111
YOOMONEY_WALLET=
# Секрет проверки подписи уведомлений (yoomoney.ru/transfer/myservices/http-notification)
YOOMONEY_NOTIFICATION_SECRET=
CURRENCY=RUB

# --- Веб-сервер для вебхука (за nginx) ---
# Боевой домен с HTTPS, например https://neurodropbot.duckdns.org
PUBLIC_BASE_URL=
WEBHOOK_PATH=/yoomoney/webhook
WEB_HOST=127.0.0.1
WEB_PORT=8080
# Куда вернуть покупателя после оплаты (по умолчанию <PUBLIC_BASE_URL>/paid)
RETURN_URL=

# --- Google Sheets ---
SHEET_ID=
GOOGLE_CREDENTIALS_FILE=/opt/neuro-dropbot/service_account.json
SHEET_CATALOG=Каталог
SHEET_KEYS=Ключи

# --- Хранилище заказов ---
DB_PATH=/opt/neuro-dropbot/data/orders.db

# --- Парсер каталога ---
SOURCE_URL=https://winkey.info
